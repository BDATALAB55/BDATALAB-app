  </div>

  {['east', 'west'].map((confId) => (
    <div 
      id={`standing-${confId === 'east' ? 'eastern' : 'western'}`} 
      class={`standing-pane ${confId === 'west' ? 'hidden' : ''} flex overflow-x-auto gap-6 no-scrollbar snap-x pb-4`}
    >
      {standings[confId].map((teamId, i) => (
        <div class="flex-none w-[280px] md:w-[320px] snap-center">
          <div class="mb-3 px-2">
            <div class="flex items-baseline text-white">
              <span class="text-5xl font-black italic leading-none">{i + 1}</span>
              <span class="text-lg font-bold uppercase ml-0.5 italic leading-none">
                {i === 0 ? 'st' : i === 1 ? 'nd' : i === 2 ? 'rd' : 'th'}
              </span>
            </div>
          </div>
          <div class="rounded-2xl overflow-hidden border border-white/10 bg-black/20 shadow-2xl transition-all hover:translate-y-[-8px]">
            <img 
              src={getTeamStatsUrl(teamId)} 
              alt={teamId}
              class="w-full h-auto block"
              loading="lazy"
              onerror="this.src='/no-image.png';" 
            />
          </div>
        </div>
      ))}
    </div>
  ))}
</section>

      

    </div>

    <div class="fixed bottom-8 right-8 z-40 pointer-events-none">
      <a href="/" class="pointer-events-auto bg-gray-800 text-white px-8 py-4 rounded-full font-black text-[11px] uppercase tracking-widest shadow-2xl active:scale-95 hover:scale-105 transition-all border border-white/10">Back to Home</a>
    </div>
  </main>
</Layout>

<script is:inline define:vars={{ reportGroups, allRankings, allPlayerCards }}>
  // --- 1. タブ切り替え ---
  const initTabs = (btnClassName) => {
    const btns = document.querySelectorAll(`.${btnClassName}`);
    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabGroup = btn.getAttribute('data-tab');
        const target = btn.getAttribute('data-target');

        document.querySelectorAll(`[data-tab="${tabGroup}"]`).forEach(b => {
          b.classList.remove('bg-white', 'text-black');
          b.classList.add('bg-black/20', 'text-white/80');
        });
        btn.classList.add('bg-white', 'text-black');
        btn.classList.remove('bg-black/20', 'text-white/80');

        if (tabGroup === 'rank') {
          document.querySelectorAll('.rank-pane').forEach(pane => pane.classList.add('hidden'));
          document.getElementById(`rank-${target}`)?.classList.remove('hidden');
        }
        if (tabGroup === 'standing') {
          document.querySelectorAll('.standing-pane').forEach(pane => pane.classList.add('hidden'));
          document.getElementById(`standing-${target}`)?.classList.remove('hidden');
        }
      });
    });
  };
  initTabs('tab-btn');
  initTabs('rank-btn');

  // --- 2. 表示モード切り替えロジック ---
  let currentViewMode = 'slide';

  const applyViewMode = () => {
    const rankPanes = document.querySelectorAll('.rank-pane');
    rankPanes.forEach(pane => {
      const cards = pane.querySelectorAll('.rank-card');
      if (currentViewMode === 'grid') {
        pane.classList.remove('flex', 'overflow-x-auto', 'snap-x', 'pb-8', 'pt-12');
        pane.classList.add('grid', 'grid-cols-2', 'md:grid-cols-3', 'lg:grid-cols-5', 'gap-x-4', 'gap-y-20', 'overflow-visible', 'pt-16'); 
        cards.forEach(c => c.classList.remove('flex-none', 'w-[260px]', 'snap-center'));
      } else {
        pane.classList.add('flex', 'overflow-x-auto', 'snap-x', 'pb-8', 'pt-12');
        pane.classList.remove('grid', 'grid-cols-2', 'md:grid-cols-3', 'lg:grid-cols-5', 'gap-x-4', 'gap-y-20', 'overflow-visible', 'pt-16');
        cards.forEach(c => c.classList.add('flex-none', 'w-[300px]', 'snap-center'));
      }
    });

    const reportSlider = document.getElementById('report-slider');
    if (reportSlider) {
      const reportCards = reportSlider.children;
      if (currentViewMode === 'grid') {
        reportSlider.classList.remove('flex', 'overflow-x-auto', 'snap-x');
        reportSlider.classList.add('grid', 'grid-cols-2', 'md:grid-cols-3', 'gap-x-4', 'gap-y-10', 'overflow-visible');
        Array.from(reportCards).forEach(c => c.classList.remove('flex-none', 'w-[300px]', 'snap-center'));
      } else {
        reportSlider.classList.add('flex', 'overflow-x-auto', 'snap-x');
        reportSlider.classList.remove('grid', 'grid-cols-2', 'md:grid-cols-3', 'gap-x-4', 'gap-y-10', 'overflow-visible');
        Array.from(reportCards).forEach(c => c.classList.add('flex-none', 'w-[300px]', 'snap-center'));
      }
    }

    const standingPanes = document.querySelectorAll('.standing-pane');
    standingPanes.forEach(pane => {
      const teamCards = pane.children;
      if (currentViewMode === 'grid') {
        // グリッド表示：横2列に変更
        pane.classList.remove('flex', 'overflow-x-auto', 'snap-x');
        pane.classList.add('grid', 'grid-cols-2', 'gap-x-4', 'gap-y-8', 'overflow-visible');
        Array.from(teamCards).forEach(c => c.classList.remove('flex-none', 'w-[280px]', 'md:w-[320px]', 'snap-center'));
      } else {
        // スライド表示：元の横スクロールに戻す
        pane.classList.add('flex', 'overflow-x-auto', 'snap-x');
        pane.classList.remove('grid', 'grid-cols-2', 'gap-x-4', 'gap-y-8', 'overflow-visible');
        Array.from(teamCards).forEach(c => c.classList.add('flex-none', 'w-[280px]', 'md:w-[320px]', 'snap-center'));
      }
    });
  };

  // --- 3. データ更新のメイン関数 (カレンダーから呼ばれる) ---
  // --- scriptタグ内の updateContentByDate 関数を以下に差し替え ---

const updateContentByDate = (targetDate) => {
  const normalizedDate = (targetDate && targetDate.length === 8) ? targetDate.substring(2) : targetDate;
  const group = reportGroups.find(g => g.id === normalizedDate);
  const rankingData = allRankings[normalizedDate];
  
  if (!group) {
    console.error("No data found for:", normalizedDate);
    return;
  }

  // 1. ゲーム数の更新
  const countEl = document.getElementById('game-count-num');
  if (countEl) countEl.innerText = group.reports.length;

  // 2. 日付表示の更新（normalizedDateから作成）
  const displayStr = `20${normalizedDate.substring(0, 2)}.${normalizedDate.substring(2, 4)}.${normalizedDate.substring(4, 6)}`;
  document.querySelectorAll('.date-display, .rank-date-display').forEach(d => {
    d.innerText = displayStr;
  });

  // 3. レポートスライダーの更新（既存のコードでOK）
  const slider = document.getElementById('report-slider');
  if (slider) {
    slider.innerHTML = group.reports.map(r => `
  <div class="flex-none w-[300px] snap-center">
    <div class="rounded-2xl overflow-hidden shadow-2xl border border-white/10 bg-black/40 aspect-[3/4.2]">
      <img src="${r.path}" class="w-full h-full object-cover" loading="lazy" />
    </div>
    <div class="mt-6 px-1">
      <a href="${r.link}" class="relative group/btn block w-full bg-gradient-to-br from-white/15 to-white/5 border border-white/10 hover:border-white/30 py-3.5 rounded-full transition-all active:scale-95 shadow-xl overflow-hidden">
        <div class="flex items-center justify-between px-6">
          <span class="text-[11px] font-black tracking-[0.2em] uppercase text-white/90">
            ${r.away_id} <span class="text-[9px] font-medium lowercase tracking-normal mx-1 text-white/40 italic">vs</span> ${r.home_id}
          </span>
          <span class="flex-shrink-0 text-[10px] text-[#2D3A56] group-hover/btn:translate-x-1 transition-transform">▶︎</span>
        </div>
      </a>
    </div>
  </div>
`).join('');
  }

  // 4. ランキングの更新
    ['PTS', 'REB', 'AST'].forEach(statType => {
      const pane = document.getElementById(`rank-${statType}`);
      if (!pane) return;

      if (!rankingData || !rankingData[statType.toLowerCase()]) {
        pane.innerHTML = `<div class="text-white/20 px-4 py-20 text-center w-full">No ranking data for this date.</div>`;
        return;
      }

      const statKey = statType.toLowerCase();
      const rawData = rankingData[statKey] || [];
      
      const sortedData = [...rawData].sort((a, b) => {
        if (Number(b[statKey]) !== Number(a[statKey])) return Number(b[statKey]) - Number(a[statKey]);
        return (a.min || "").localeCompare(b.min || "");
      }).slice(0, 10);

      pane.innerHTML = sortedData.map((player, i) => {
        // --- ブラウザ側での高度な画像検索ロジック ---
        let cardUrl = "/no-player.png";
        
        // 1. JSONにあるcardPathからGame IDを抽出 (例: "game_12345_...")
        const gameMatch = player.cardPath ? player.cardPath.match(/game_(\d+)_/i) : null;
        const gameId = gameMatch ? gameMatch[1] : null;

        // 2. 検索用の名前を生成
        const rawName = player.name ? player.name.trim().toUpperCase() : "";
        const nameWithUnderscore = rawName.replace(/\s+/g, '_');
        const nameClean = nameWithUnderscore.replace(/['.]/g, '');

        // 3. 全画像リスト(allPlayerCards)から最適なものを探す
        const found = allPlayerCards.find(item => {
          const p = item.path.toUpperCase();
          const isSameGame = gameId ? p.includes(gameId) : true;
          const matchName = p.includes(nameWithUnderscore) || p.includes(nameClean);
          return isSameGame && matchName;
        });

        if (found) {
          cardUrl = `https://raw.githubusercontent.com/BDATALAB55/BDL-game-player-cards/main/${found.path}`;
        } else {
          // 4. フォールバック: Game IDが一致しなくても名前が合えばOKとする
          const fallback = allPlayerCards.find(item => {
            const p = item.path.toUpperCase();
            return p.includes(nameWithUnderscore) || p.includes(nameClean);
          });
          if (fallback) {
            cardUrl = `https://raw.githubusercontent.com/BDATALAB55/BDL-game-player-cards/main/${fallback.path}`;
          }
        }

        return `
          <div class="rank-card flex-none w-[300px] md:w-[210px] snap-center">
            <div class="relative group">
              <div class="absolute -top-11 left-1 z-10 flex items-baseline">
                <span class="text-4xl font-black italic text-white leading-none">${i + 1}</span>
                <span class="text-[10px] font-bold uppercase ml-0.5 text-white/70">${['st','nd','rd'][i] || 'th'}</span>
              </div>
              <div class="relative aspect-[3/4.2] rounded-2xl overflow-hidden shadow-2xl border border-white/10 bg-black/40">
                <img src="${cardUrl}" alt="${player.name}" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="mt-4 px-1">
                <a href="/nba-players?name=${encodeURIComponent(player.name)}" class="relative group/btn block w-full bg-gradient-to-br from-white/15 to-white/5 border border-white/10 hover:border-white/30 py-3.5 rounded-full transition-all active:scale-95 shadow-xl">
                  <div class="flex items-center justify-between px-6">
                    <span class="text-[10px] font-black uppercase tracking-[0.2em] text-white/90 truncate mr-2">${player.name}</span>
                    <span class="flex-shrink-0 text-[10px] text-[#2D3A56] group-hover/btn:translate-x-1 transition-transform">▶︎</span>
                  </div>
                </a>
              </div>
            </div>
          </div>`;
      }).join('');
    });

    // 表示モードの再適用
    applyViewMode();
  };

  // --- 4. カレンダーの描画 ---
  const calendarEl = document.getElementById('calendar');
  const availableDates = reportGroups.map(g => g.id);
  const latestDate = availableDates[0]; // 例: "260220"

  // 最新データの日付からカレンダーの初期表示を決定
  let curY = latestDate ? parseInt("20" + latestDate.substring(0, 2)) : 2026;
  let curM = latestDate ? parseInt(latestDate.substring(2, 4)) - 1 : 1;

  function renderCalendar(y, m) {
    if (!calendarEl) return;
    const daysInMonth = new Date(y, m + 1, 0).getDate();
    const firstDay = new Date(y, m, 1).getDay();
    const monthNames = ["JANUARY", "FEBRUARY", "MARCH", "APRIL", "MAY", "JUNE", "JULY", "AUGUST", "SEPTEMBER", "OCTOBER", "NOVEMBER", "DECEMBER"];
    
    let html = `<div class="flex justify-between items-center mb-6 px-2 text-white font-black text-xs tracking-widest">
      <button type="button" class="p-2 hover:text-[#2D3A56]" id="prevM">←</button>
      <span>${monthNames[m]} ${y}</span>
      <button type="button" class="p-2 hover:text-[#2D3A56]" id="nextM">→</button>
    </div>
    <div class="grid grid-cols-7 gap-1 text-[9px] text-center text-white/40 mb-4 font-bold uppercase">
      <div>S</div><div>M</div><div>T</div><div>W</div><div>T</div><div>F</div><div>S</div>
    </div>
    <div class="grid grid-cols-7 gap-y-3">`;

    for (let i = 0; i < firstDay; i++) html += '<div></div>';
    for (let d = 1; d <= daysInMonth; d++) {
      const dateId = `${String(y).slice(-2)}${('0'+(m+1)).slice(-2)}${('0'+d).slice(-2)}`;
      const hasData = availableDates.includes(dateId);
      const isSelected = dateId === latestDate;
      const activeStyle = hasData ? "bg-[#2D3A56] text-white font-black cursor-pointer shadow-lg scale-110" : "text-white/10 pointer-events-none";
      html += `<div class="aspect-square flex items-center justify-center rounded-full text-[12px] transition-all ${activeStyle}" data-date="${dateId}">${d}</div>`;
    }
    calendarEl.innerHTML = html + '</div>';

    document.getElementById('prevM').onclick = () => { curM--; if(curM<0){curM=11;curY--} renderCalendar(curY, curM); };
    document.getElementById('nextM').onclick = () => { curM++; if(curM>11){curM=0;curY++} renderCalendar(curY, curM); };
    
    calendarEl.querySelectorAll('[data-date]').forEach(el => {
      el.onclick = () => updateContentByDate(el.getAttribute('data-date'));
    });
  }

  // --- 初期実行 ---
if (availableDates.length > 0) {
  // データがある場合、最新の日付でカレンダーとコンテンツを初期化
  const defaultDate = availableDates[0];
  renderCalendar(curY, curM);
  updateContentByDate(defaultDate);
} else {
  // データがない場合のフォールバック
  renderCalendar(curY, curM);
  console.warn("表示できるデータが見つかりません。");
}

  // 表示モードボタンのイベントリスナー
  document.querySelectorAll('.view-switch-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentViewMode = btn.getAttribute('data-view-mode');
      
      // ボタンの見た目を更新
      document.querySelectorAll('.view-switch-btn').forEach(b => {
        const isActive = b.getAttribute('data-view-mode') === currentViewMode;
        if (isActive) {
          b.classList.add('bg-white/20', 'text-white');
          b.classList.remove('bg-black/40', 'text-white/60');
        } else {
          b.classList.remove('bg-white/20', 'text-white');
          b.classList.add('bg-black/40', 'text-white/60');
        }
      });
      
      applyViewMode();
    });
  });

  // 初回読み込み時にも適用
  applyViewMode();
</script>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>